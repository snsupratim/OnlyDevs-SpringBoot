<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="onlyDev_Users" pageWidth="842" pageHeight="595" orientation="Landscape"
			  columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

	<!-- QUERY -->
	<queryString>
		<![CDATA[
            SELECT name, emailid, roles FROM users
        ]]>
	</queryString>

	<!-- FIELDS -->
	<field name="name" class="java.lang.String"/>
	<field name="emailid" class="java.lang.String"/>
	<field name="roles" class="java.lang.String"/>

	<!-- TITLE -->
	<title>
		<band height="80">
			<staticText>
				<reportElement x="0" y="10" width="802" height="40"/>
				<textElement textAlignment="Center">
					<font size="26" isBold="true"/>
				</textElement>
				<text><![CDATA[ONLYDEV USER REPORT]]></text>
			</staticText>

			<textField pattern="dd-MM-yyyy HH:mm">
				<reportElement x="600" y="50" width="200" height="20"/>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
		</band>
	</title>

	<!-- COLUMN HEADER -->
	<columnHeader>
		<band height="40">

			<!-- Background -->
			<rectangle>
				<reportElement x="0" y="0" width="802" height="40" backcolor="#2C3E50" mode="Opaque"/>
			</rectangle>

			<!-- Headers -->
			<staticText>
				<reportElement x="0" y="10" width="200" height="20"/>
				<textElement textAlignment="Center">
					<font isBold="true" size="14" pdfFontName="Helvetica-Bold"/>
				</textElement>
				<text><![CDATA[NAME]]></text>
			</staticText>

			<staticText>
				<reportElement x="200" y="10" width="350" height="20"/>
				<textElement textAlignment="Center">
					<font isBold="true" size="14"/>
				</textElement>
				<text><![CDATA[EMAIL]]></text>
			</staticText>

			<staticText>
				<reportElement x="550" y="10" width="252" height="20"/>
				<textElement textAlignment="Center">
					<font isBold="true" size="14"/>
				</textElement>
				<text><![CDATA[ROLE]]></text>
			</staticText>

		</band>
	</columnHeader>

	<!-- DETAIL (ROWS) -->
	<detail>
		<band height="30">

			<!-- Row Border -->
			<rectangle>
				<reportElement x="0" y="0" width="802" height="30" mode="Transparent"/>
			</rectangle>

			<!-- Name -->
			<textField>
				<reportElement x="0" y="5" width="200" height="20"/>
				<textElement textAlignment="Left"/>
				<textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
			</textField>

			<!-- Email -->
			<textField>
				<reportElement x="200" y="5" width="350" height="20"/>
				<textElement textAlignment="Left"/>
				<textFieldExpression><![CDATA[$F{emailid}]]></textFieldExpression>
			</textField>

			<!-- Role -->
			<textField>
				<reportElement x="550" y="5" width="252" height="20"/>
				<textElement textAlignment="Center"/>
				<textFieldExpression><![CDATA[$F{roles}]]></textFieldExpression>
			</textField>

		</band>
	</detail>

	<!-- FOOTER -->
	<pageFooter>
		<band height="30">
			<staticText>
				<reportElement x="0" y="5" width="802" height="20"/>
				<textElement textAlignment="Center">
					<font size="10"/>
				</textElement>
				<text><![CDATA[Generated by OnlyDev System]]></text>
			</staticText>
		</band>
	</pageFooter>

</jasperReport>